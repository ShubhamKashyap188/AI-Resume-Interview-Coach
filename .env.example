# Backend
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
PORT=4000

# Frontend API URL
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:4000

# Production (Vercel):
# Set this in Vercel Environment Variables to your deployed backend URL
# Example: https://your-project.vercel.app

# PDF Processing Control (Vercel-only)
# Set in Vercel to disable canvas requirement
PDFJS_DISABLE_CANVAS=true
